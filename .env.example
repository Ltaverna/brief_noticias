# OpenAI
OPENAI_API_KEY=sk-...

# Database
POSTGRES_USER=noticias
POSTGRES_PASSWORD=noticias
POSTGRES_DB=noticias
DATABASE_URL=postgresql+psycopg://noticias:noticias@postgres:5432/noticias

# API
API_PORT=8000
LOG_LEVEL=INFO

# Pipeline cron — set ONE of these:
CRON_HOUR=7                # legacy: single run hour (default 7am)
# CRON_HOURS=7,13,20       # multiple times per day, CSV (overrides CRON_HOUR)
CRON_MINUTE=0
TOP_N_CLUSTERS=15
SIMILARITY_THRESHOLD=0.78
MERGE_THRESHOLD=0.85
MERGE_WINDOW_HOURS=72
SAGA_THRESHOLD=0.78
SAGA_WINDOW_HOURS=168

# Frontend
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://api:8000
PUBLIC_BASE_URL=http://localhost:3000

# Entity extraction
ENABLE_ENTITY_EXTRACTION=true
ENTITY_EXTRACTION_MODEL=gpt-4o-mini

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ENABLE_TELEGRAM=false

# Telegram bot interaction (Q&A via chat)
# 'off' (default), 'polling' (works locally without public URL),
# 'webhook' (needs PUBLIC_BASE_URL via Cloudflare Tunnel / similar)
TELEGRAM_BOT_MODE=off
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHATS=

# RAG upgrades
COHERE_API_KEY=                # optional; if unset, reranking is skipped
ENABLE_HYDE=true
ENABLE_RERANKING=true
QA_HISTORY_TURNS=6

# CRAG-lite — corrective RAG with per-chunk relevance evaluation
# Set ENABLE_CRAG=false to skip the relevance step (faster but less honest)
ENABLE_CRAG=true
CRAG_MIN_RELEVANT=3            # chunks classified "relevant" needed for "confident" confidence
